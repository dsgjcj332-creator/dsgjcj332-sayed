# Environment Variables Template
# Copy this file to .env.local and fill in your values for local development

# Local Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=fitness

# Production Database (Railway)
# Uncomment and fill when deploying
# DB_HOST=your_railway_mysql_host
# DB_PORT=3306
# DB_USER=your_railway_user
# DB_PASS=your_railway_password
# DB_NAME=your_railway_database

# API Keys
# GEMINI_API_KEY=your_gemini_api_key_here
# CLAUDE_API_KEY=your_claude_api_key_here

# App Settings
APP_ENV=development
APP_DEBUG=true
